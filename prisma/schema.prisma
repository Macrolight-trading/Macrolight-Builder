generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Application models ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  plan          Plan      @default(STARTER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  payments   Payment[]

  // CRM relations
  ownedLeads     Lead[]     @relation("LeadOwner")
  ownedDeals     Deal[]     @relation("DealOwner")
  ownedActivities Activity[] @relation("ActivityOwner")
  authoredNotes  Note[]     @relation("NoteAuthor")

  @@map("users")
}

model Payment {
  id          String        @id @default(cuid())
  amount      Int           // cents
  currency    String        @default("usd")
  status      PaymentStatus @default(SUCCEEDED)
  description String?
  userId      String
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String
  phone        String?
  company      String?
  industry     String?
  message      String        @db.Text
  status       ContactStatus @default(NEW)
  emailSentAt  DateTime?
  createdAt    DateTime      @default(now())

  // Optional linkage to a CRM Lead when the contact gets converted.
  lead         Lead?

  @@map("contacts")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

// ── CRM models ──────────────────────────────────────────────────────────────

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  jobTitle    String?
  industry    String?
  website     String?
  source      String?    // website, referral, outbound, ad, etc.
  status      LeadStatus @default(NEW)
  value       Int?       // potential value in cents
  description String?    @db.Text

  // Optional link back to the original contact-form submission
  contactId   String?   @unique
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Optional owner (sales rep)
  ownerId     String?
  owner       User?     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  deals       Deal[]
  activities  Activity[]
  noteRecords Note[]
  tags        TagsOnLeads[]

  lastContactedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Int        // cents
  currency          String     @default("usd")
  stage             DealStage  @default(PROSPECT)
  probability       Int        @default(10) // 0-100
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?

  leadId            String?
  lead              Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  ownerId           String?
  owner             User?      @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  activities        Activity[]
  noteRecords       Note[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([stage])
  @@index([createdAt])
  @@map("deals")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?      @db.Text
  dueDate     DateTime?
  completedAt DateTime?

  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  ownerId     String?
  owner       User?        @relation("ActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([dueDate])
  @@index([completedAt])
  @@map("activities")
}

model Note {
  id          String   @id @default(cuid())
  body        String   @db.Text

  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?    @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notes")
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  color String        @default("#6b7280")
  leads TagsOnLeads[]

  @@map("tags")
}

model TagsOnLeads {
  leadId  String
  tagId   String
  lead    Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag     Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("tags_on_leads")
}

// ── SEO Audit models ────────────────────────────────────────────────────────

model AuditJob {
  id          String       @id @default(cuid())
  url         String
  clientName  String
  status      AuditStatus  @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?      @db.Text
  createdBy   String?      // userId of admin who triggered it
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  result AuditResult?

  @@index([status])
  @@index([createdAt])
  @@map("audit_jobs")
}

model AuditResult {
  id                    String   @id @default(cuid())
  jobId                 String   @unique
  job                   AuditJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  overallScore          Int
  technicalScore        Int
  onPageScore           Int
  backlinkScore         Int
  localSeoScore         Int
  domainAnalyticsScore  Int      @default(0)
  serpScore             Int      @default(0)
  // New scored modules — nullable so "not run yet" reads cleanly without
  // a sentinel-zero. Older audits will have null here.
  localPackScore        Int?
  reputationScore       Int?
  issues                Json     // structured array of AuditIssue objects
  rawData               Json     // full API responses for reference
  pdfUrl                String?  // link to generated PDF
  // AI-generated content plan — populated on-demand via the
  // /api/audits/[id]/content-plan endpoint after the audit completes.
  // Null until the admin clicks "Generate Content Plan".
  aiContentPlan         Json?
  aiContentPlanAt       DateTime?
  createdAt             DateTime @default(now())

  @@map("audit_results")
}

// ── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Plan {
  STARTER
  GROWTH
  PRO
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum DealStage {
  PROSPECT
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}
