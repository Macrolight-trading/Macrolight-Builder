generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  // Optional phone number collected at signup (or later). Stored as a
  // free-form string so we can keep whatever format the user typed —
  // normalize at the point of use (e.g. when dialing or texting via
  // Twilio) rather than at write-time.
  phone         String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  plan          Plan      @default(NONE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stripeCustomerId String? @unique

  accounts      Account[]
  sessions      Session[]
  payments      Payment[]
  subscriptions Subscription[]
  bookings      Booking[]

  ownedLeads      Lead[]     @relation("LeadOwner")
  ownedDeals      Deal[]     @relation("DealOwner")
  ownedActivities Activity[] @relation("ActivityOwner")
  authoredNotes   Note[]     @relation("NoteAuthor")

  project            Project?
  messages           Message[]
  mediaFiles         MediaFile[]
  onboarding         OnboardingData?
  planRequests       CustomPlanRequest[]
  planRecommendation PlanRecommendation?

  @@map("users")
}

model Payment {
  id          String        @id @default(cuid())
  amount      Int
  currency    String        @default("usd")
  status      PaymentStatus @default(SUCCEEDED)
  description String?
  userId      String
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Contact {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  industry    String?
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  emailSentAt DateTime?
  createdAt   DateTime      @default(now())

  lead Lead?

  @@map("contacts")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  jobTitle    String?
  industry    String?
  website     String?
  source      String?
  status      LeadStatus @default(NEW)
  value       Int?
  description String?    @db.Text

  contactId String?  @unique
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  deals       Deal[]
  activities  Activity[]
  noteRecords Note[]
  tags        TagsOnLeads[]

  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  value             Int
  currency          String    @default("usd")
  stage             DealStage @default(PROSPECT)
  probability       Int       @default(10)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?

  leadId  String?
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  ownerId String?
  owner   User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  activities  Activity[]
  noteRecords Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([createdAt])
  @@map("deals")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?      @db.Text
  dueDate     DateTime?
  completedAt DateTime?

  leadId  String?
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId  String?
  deal    Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  ownerId String?
  owner   User?   @relation("ActivityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueDate])
  @@index([completedAt])
  @@map("activities")
}

model Note {
  id   String @id @default(cuid())
  body String @db.Text

  leadId   String?
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId   String?
  deal     Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?   @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  color String        @default("#6b7280")
  leads TagsOnLeads[]

  @@map("tags")
}

model TagsOnLeads {
  leadId String
  tagId  String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("tags_on_leads")
}

model AuditJob {
  id          String      @id @default(cuid())
  url         String
  clientName  String
  status      AuditStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?     @db.Text
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  result AuditResult?

  @@index([status])
  @@index([createdAt])
  @@map("audit_jobs")
}

model AuditResult {
  id                   String    @id @default(cuid())
  jobId                String    @unique
  job                  AuditJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  overallScore         Int
  technicalScore       Int
  onPageScore          Int
  backlinkScore        Int
  localSeoScore        Int
  domainAnalyticsScore Int       @default(0)
  serpScore            Int       @default(0)
  localPackScore       Int?
  reputationScore      Int?
  issues               Json
  rawData              Json
  pdfUrl               String?
  aiContentPlan        Json?
  aiContentPlanAt      DateTime?
  createdAt            DateTime  @default(now())

  @@map("audit_results")
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  NONE
  STARTER
  GROWTH
  PRO
  CUSTOM
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum DealStage {
  PROSPECT
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

model Project {
  id         String       @id @default(cuid())
  userId     String       @unique
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage      ProjectStage @default(ONBOARDING)
  liveUrl    String?
  previewUrl String?
  notes      String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("projects")
}

model Message {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAdmin Boolean   @default(false)
  body      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

model MediaFile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  url         String
  contentType String
  size        Int
  category    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("media_files")
}

model OnboardingData {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String?
  tagline         String?
  primaryColor    String?
  secondaryColor  String?
  targetAudience  String?   @db.Text
  keyServices     String?   @db.Text
  competitors     String?   @db.Text
  tone            String?
  themePicks      String?
  inspirationUrls String?   @db.Text
  additionalNotes String?   @db.Text
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("onboarding_data")
}

enum ProjectStage {
  ONBOARDING
  DESIGN
  DEVELOPMENT
  REVIEW
  LAUNCHED
}

enum BillingType {
  ONE_TIME
  MONTHLY
}

enum PlanRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PlanRequestSource {
  QUOTE
  CHECKOUT
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

model PlanOption {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  category    String
  priceCents  Int
  billingType BillingType
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items               CustomPlanRequestItem[]
  recommendationItems PlanRecommendationItem[]
  subscriptionItems   SubscriptionItem[]
  defaultTemplateItems DefaultPlanTemplateItem[]

  @@index([active, category, sortOrder])
  @@map("plan_options")
}

model CustomPlanRequest {
  id                  String            @id @default(cuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  basePlan            Plan              @default(STARTER)
  status              PlanRequestStatus @default(PENDING)
  source              PlanRequestSource @default(QUOTE)
  monthlyCents        Int               @default(0)
  oneTimeCents        Int               @default(0)
  bundleDiscountCents Int               @default(0)
  notes               String?           @db.Text
  adminNotes          String?           @db.Text
  reviewedAt          DateTime?
  reviewedById        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  stripeCheckoutSessionId String?       @unique
  // NOT unique — every modify produces a fresh CustomPlanRequest pointing
  // at the same Stripe subscription. Idempotency for a single checkout
  // attempt is keyed off stripeCheckoutSessionId.
  stripeSubscriptionId    String?
  subscription            Subscription? @relation(fields: [stripeSubscriptionId], references: [stripeSubscriptionId], onDelete: SetNull)

  sowPdfUrl      String?
  sowGeneratedAt DateTime?

  items CustomPlanRequestItem[]

  @@index([userId])
  @@index([status, createdAt])
  @@index([stripeSubscriptionId])
  @@map("custom_plan_requests")
}

model CustomPlanRequestItem {
  id                 String            @id @default(cuid())
  requestId          String
  request            CustomPlanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  optionId           String?
  option             PlanOption?       @relation(fields: [optionId], references: [id], onDelete: SetNull)
  nameSnapshot       String
  priceCents         Int
  billingType        BillingType
  category           String
  includedInBasePlan Boolean           @default(false)

  @@index([requestId])
  @@map("custom_plan_request_items")
}

model PlanRecommendation {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  basePlan    Plan     @default(NONE)
  notes       String?  @db.Text
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PlanRecommendationItem[]

  @@map("plan_recommendations")
}

model PlanRecommendationItem {
  id               String             @id @default(cuid())
  recommendationId String
  recommendation   PlanRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  optionId         String
  option           PlanOption         @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, optionId])
  @@index([recommendationId])
  @@map("plan_recommendation_items")
}

/**
 * Singleton default template applied to every new signup.
 * There is exactly one row (id = "default").
 * Admins edit this at /admin/portal/plan-recommendations/default.
 */
model DefaultPlanTemplate {
  id        String   @id @default("default")
  basePlan  Plan     @default(STARTER)
  notes     String?  @db.Text
  updatedAt DateTime @updatedAt

  items DefaultPlanTemplateItem[]

  @@map("default_plan_template")
}

model DefaultPlanTemplateItem {
  id         String              @id @default(cuid())
  templateId String
  template   DefaultPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  optionId   String
  option     PlanOption          @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([templateId, optionId])
  @@index([templateId])
  @@map("default_plan_template_items")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  status               SubscriptionStatus @default(INCOMPLETE)
  basePlan             Plan               @default(NONE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  items        SubscriptionItem[]
  /// Every modify-flow checkout writes a fresh CustomPlanRequest tied to
  /// the same subscription — one-to-many so the history is queryable.
  planRequests CustomPlanRequest[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeItemId   String       @unique
  optionId       String?
  option         PlanOption?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  nameSnapshot   String
  priceCents     Int
  billingType    BillingType  @default(MONTHLY)
  quantity       Int          @default(1)
  kind           String       @default("addon")

  @@index([subscriptionId])
  @@map("subscription_items")
}

// ── Hermes Event Queue ──────────────────────────────────────────────────────
// Durable queue for app → Hermes agent notifications.
// Hermes polls /api/hermes/events, processes each pending event, then ACKs.

model HermesEvent {
  id          String            @id @default(cuid())
  event       String            // e.g. "onboarding_complete", "payment_confirmed"
  userId      String?
  payload     Json              // event-specific context
  status      HermesEventStatus @default(PENDING)
  processedAt DateTime?
  error       String?           @db.Text
  createdAt   DateTime          @default(now())

  @@index([status, createdAt])
  @@map("hermes_events")
}

enum HermesEventStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model PlanCategory {
  id                String   @id @default(cuid())
  name              String   @unique
  label             String?
  bundleDiscountPct Int      @default(0)
  includedFromTier  Plan?
  sortOrder         Int      @default(0)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("plan_categories")
}

// ── Booking (Cal.com mirror) ────────────────────────────────────────────────

enum BookingStatus {
  CONFIRMED
  PENDING
  CANCELED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

/// Mirror of a Cal.com (or future provider) booking. Cal.com remains the
/// system of record — this table exists so the portal can show "Your
/// upcoming calls" without a round-trip to Cal's API, and so admin / CRM
/// tooling can query against bookings locally.
model Booking {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Cal.com booking UID (e.g. "abc123"). Unique per provider; collisions
  /// across providers are unlikely but we don't enforce.
  externalId     String?       @unique
  /// "cal.com" today. Reserved for future schedulers.
  externalSource String        @default("cal.com")
  status         BookingStatus @default(CONFIRMED)
  startsAt       DateTime
  endsAt         DateTime
  title          String?
  attendeeName   String?
  attendeeEmail  String?
  /// Slug of the Cal.com event type that produced the booking (e.g.
  /// "strategy-call"). Lets us filter by call type later.
  callType       String?
  notes          String?       @db.Text
  /// Conference link (Zoom, Google Meet, Cal video).
  meetingUrl     String?
  /// User-facing self-service links provided by Cal.com.
  cancelUrl      String?
  rescheduleUrl  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([startsAt])
  @@index([status, startsAt])
  @@map("bookings")
}
