generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String              @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               Role                @default(USER)
  plan               Plan                @default(NONE)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  stripeCustomerId   String?             @unique
  phone              String?
  accounts           Account[]
  sessions           Session[]
  ownedActivities    Activity[]          @relation("ActivityOwner")
  bookings           Booking[]
  planRequests       CustomPlanRequest[]
  ownedDeals         Deal[]              @relation("DealOwner")
  ownedLeads         Lead[]              @relation("LeadOwner")
  mediaFiles         MediaFile[]
  messages           Message[]
  authoredNotes      Note[]              @relation("NoteAuthor")
  onboarding         OnboardingData?
  payments           Payment[]
  planRecommendation PlanRecommendation?
  project            Project?
  subscriptions      Subscription[]
  hermesEvents       HermesEvent[]
  deliverySchedule   ClientDeliverySchedule?
  deliveryTasks      DeliveryTask[]

  @@map("users")
}

model Payment {
  id          String        @id @default(cuid())
  amount      Int
  currency    String        @default("usd")
  status      PaymentStatus @default(SUCCEEDED)
  description String?
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Contact {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  industry    String?
  message     String
  status      ContactStatus @default(NEW)
  emailSentAt DateTime?
  createdAt   DateTime      @default(now())
  lead        Lead?

  @@map("contacts")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

model Lead {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String?
  company         String?
  jobTitle        String?
  industry        String?
  website         String?
  source          String?
  status          LeadStatus    @default(NEW)
  value           Int?
  description     String?
  contactId       String?       @unique
  ownerId         String?
  lastContactedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activities      Activity[]
  deals           Deal[]
  contact         Contact?      @relation(fields: [contactId], references: [id])
  owner           User?         @relation("LeadOwner", fields: [ownerId], references: [id])
  noteRecords     Note[]
  tags            TagsOnLeads[]

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Int
  currency          String     @default("usd")
  stage             DealStage  @default(PROSPECT)
  probability       Int        @default(10)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  lostReason        String?
  leadId            String?
  ownerId           String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  activities        Activity[]
  lead              Lead?      @relation(fields: [leadId], references: [id])
  owner             User?      @relation("DealOwner", fields: [ownerId], references: [id])
  noteRecords       Note[]

  @@index([stage])
  @@index([createdAt])
  @@map("deals")
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  leadId      String?
  dealId      String?
  ownerId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  owner       User?        @relation("ActivityOwner", fields: [ownerId], references: [id])

  @@index([dueDate])
  @@index([completedAt])
  @@map("activities")
}

model Note {
  id        String   @id @default(cuid())
  body      String
  leadId    String?
  dealId    String?
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation("NoteAuthor", fields: [authorId], references: [id])
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  color String        @default("#6b7280")
  leads TagsOnLeads[]

  @@map("tags")
}

model TagsOnLeads {
  leadId String
  tagId  String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("tags_on_leads")
}

model AuditJob {
  id          String       @id @default(cuid())
  url         String
  clientName  String
  status      AuditStatus  @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  result      AuditResult?

  @@index([status])
  @@index([createdAt])
  @@map("audit_jobs")
}

model AuditResult {
  id                   String    @id @default(cuid())
  jobId                String    @unique
  overallScore         Int
  technicalScore       Int
  onPageScore          Int
  backlinkScore        Int
  localSeoScore        Int
  issues               Json
  rawData              Json
  pdfUrl               String?
  createdAt            DateTime  @default(now())
  domainAnalyticsScore Int       @default(0)
  serpScore            Int       @default(0)
  localPackScore       Int?
  reputationScore      Int?
  aiContentPlan        Json?
  aiContentPlanAt      DateTime?
  job                  AuditJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("audit_results")
}

model Project {
  id         String       @id @default(cuid())
  userId     String       @unique
  stage      ProjectStage @default(ONBOARDING)
  liveUrl    String?
  notes      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  previewUrl String?
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Message {
  id        String    @id @default(cuid())
  userId    String
  fromAdmin Boolean   @default(false)
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

model MediaFile {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  url         String
  contentType String
  size        Int
  category    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("media_files")
}

model OnboardingData {
  id               String    @id @default(cuid())
  userId           String    @unique
  businessName     String?
  tagline          String?
  primaryColor     String?
  secondaryColor   String?
  targetAudience   String?
  keyServices      String?
  competitors      String?
  tone             String?
  additionalNotes  String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  themePicks       String?
  inspirationUrls  String?
  contactName      String?
  phone            String?
  address          String?
  briefMarkdownUrl String?
  chatMessages     Json?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_data")
}

model PlanOption {
  id                   String                    @id @default(cuid())
  name                 String
  description          String?
  category             String
  priceCents           Int
  billingType          BillingType
  active               Boolean                   @default(true)
  sortOrder            Int                       @default(0)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  items                CustomPlanRequestItem[]
  defaultTemplateItems DefaultPlanTemplateItem[]
  recommendationItems  PlanRecommendationItem[]
  subscriptionItems    SubscriptionItem[]

  @@index([active, category, sortOrder])
  @@map("plan_options")
}

model CustomPlanRequest {
  id                      String                  @id @default(cuid())
  userId                  String
  basePlan                Plan                    @default(STARTER)
  status                  PlanRequestStatus       @default(PENDING)
  monthlyCents            Int                     @default(0)
  oneTimeCents            Int                     @default(0)
  notes                   String?
  adminNotes              String?
  reviewedAt              DateTime?
  reviewedById            String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  bundleDiscountCents     Int                     @default(0)
  source                  PlanRequestSource       @default(QUOTE)
  stripeCheckoutSessionId String?                 @unique
  stripeSubscriptionId    String?
  sowGeneratedAt          DateTime?
  sowPdfUrl               String?
  items                   CustomPlanRequestItem[]
  subscription            Subscription?           @relation(fields: [stripeSubscriptionId], references: [stripeSubscriptionId])
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status, createdAt])
  @@index([stripeSubscriptionId])
  @@map("custom_plan_requests")
}

model CustomPlanRequestItem {
  id                 String            @id @default(cuid())
  requestId          String
  optionId           String?
  nameSnapshot       String
  priceCents         Int
  billingType        BillingType
  category           String
  includedInBasePlan Boolean           @default(false)
  option             PlanOption?       @relation(fields: [optionId], references: [id])
  request            CustomPlanRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("custom_plan_request_items")
}

model PlanRecommendation {
  id          String                   @id @default(cuid())
  userId      String                   @unique
  basePlan    Plan                     @default(NONE)
  notes       String?
  createdById String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  items       PlanRecommendationItem[]
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("plan_recommendations")
}

model PlanRecommendationItem {
  id               String             @id @default(cuid())
  recommendationId String
  optionId         String
  option           PlanOption         @relation(fields: [optionId], references: [id], onDelete: Cascade)
  recommendation   PlanRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, optionId])
  @@index([recommendationId])
  @@map("plan_recommendation_items")
}

/// *
///  * Singleton default template applied to every new signup.
///  * There is exactly one row (id = "default").
///  * Admins edit this at /admin/portal/plan-recommendations/default.
model DefaultPlanTemplate {
  id        String                    @id @default("default")
  basePlan  Plan                      @default(STARTER)
  notes     String?
  updatedAt DateTime                  @updatedAt
  items     DefaultPlanTemplateItem[]

  @@map("default_plan_template")
}

model DefaultPlanTemplateItem {
  id         String              @id @default(cuid())
  templateId String
  optionId   String
  option     PlanOption          @relation(fields: [optionId], references: [id], onDelete: Cascade)
  template   DefaultPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, optionId])
  @@index([templateId])
  @@map("default_plan_template_items")
}

model Subscription {
  id                   String              @id @default(cuid())
  userId               String
  stripeSubscriptionId String              @unique
  stripeCustomerId     String
  status               SubscriptionStatus  @default(INCOMPLETE)
  basePlan             Plan                @default(NONE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean             @default(false)
  canceledAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  planRequests         CustomPlanRequest[]
  items                SubscriptionItem[]
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  stripeItemId   String       @unique
  optionId       String?
  nameSnapshot   String
  priceCents     Int
  billingType    BillingType  @default(MONTHLY)
  quantity       Int          @default(1)
  kind           String       @default("addon")
  option         PlanOption?  @relation(fields: [optionId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_items")
}

model HermesEvent {
  id          String            @id @default(cuid())
  event       String
  userId      String?
  payload     Json
  status      HermesEventStatus @default(PENDING)
  processedAt DateTime?
  error       String?
  createdAt   DateTime          @default(now())
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("hermes_events")
}

/// Fulfillment schedule for a paid client — checklist + calendar dates.
model ClientDeliverySchedule {
  id                   String         @id @default(cuid())
  userId               String         @unique
  anchorAt             DateTime
  basePlan             Plan           @default(NONE)
  planRequestId        String?
  subscriptionId       String?
  lastSyncedAt         DateTime       @default(now())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                DeliveryTask[]

  @@index([anchorAt])
  @@map("client_delivery_schedules")
}

model DeliveryTask {
  id                 String                 @id @default(cuid())
  scheduleId         String
  userId             String
  sourceKey          String
  title              String
  category           String                 @default("General")
  kind               DeliveryTaskKind       @default(ONE_TIME)
  billingType        BillingType            @default(ONE_TIME)
  optionId           String?
  includedInBasePlan Boolean                @default(false)
  dueAt              DateTime?
  recurrence         DeliveryRecurrence     @default(NONE)
  nextDueAt          DateTime?
  completedAt        DateTime?
  lastCompletedAt    DateTime?
  sortOrder          Int                    @default(0)
  active             Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  schedule           ClientDeliverySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, sourceKey])
  @@index([userId, active, dueAt])
  @@index([userId, active, nextDueAt])
  @@index([active, dueAt])
  @@index([active, nextDueAt])
  @@map("delivery_tasks")
}

model PlanCategory {
  id                String   @id @default(cuid())
  name              String   @unique
  label             String?
  bundleDiscountPct Int      @default(0)
  sortOrder         Int      @default(0)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  includedFromTier  Plan?

  @@map("plan_categories")
}

/// Mirror of a Cal.com (or future provider) booking. Cal.com remains the
/// system of record — this table exists so the portal can show "Your
/// upcoming calls" without a round-trip to Cal's API, and so admin / CRM
/// tooling can query against bookings locally.
model Booking {
  id             String        @id @default(cuid())
  userId         String
  /// Cal.com booking UID (e.g. "abc123"). Unique per provider; collisions
  /// across providers are unlikely but we don't enforce.
  externalId     String?       @unique
  /// "cal.com" today. Reserved for future schedulers.
  externalSource String        @default("cal.com")
  status         BookingStatus @default(CONFIRMED)
  startsAt       DateTime
  endsAt         DateTime
  title          String?
  attendeeName   String?
  attendeeEmail  String?
  /// Slug of the Cal.com event type that produced the booking (e.g.
  /// "strategy-call"). Lets us filter by call type later.
  callType       String?
  notes          String?
  /// Conference link (Zoom, Google Meet, Cal video).
  meetingUrl     String?
  /// User-facing self-service links provided by Cal.com.
  cancelUrl      String?
  rescheduleUrl  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([startsAt])
  @@index([status, startsAt])
  @@map("bookings")
}

model account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([provider, providerAccountId])
}

model organization_members {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String        @db.Uuid
  user_id         String
  role            String        @default("member")
  created_at      DateTime      @default(now())
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user            user          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organization_id], map: "organization_members_org_id_idx")
  @@index([user_id])
}

model organizations {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  slug                 String                 @unique
  created_at           DateTime               @default(now())
  organization_members organization_members[]
}

model session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user {
  id                   String                 @id
  name                 String?
  email                String                 @unique
  emailVerified        DateTime?
  image                String?
  password_hash        String?
  account              account[]
  organization_members organization_members[]
  session              session[]
}

model verificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  STARTER
  GROWTH
  PRO
  NONE
  CUSTOM
}

enum PaymentStatus {
  SUCCEEDED
  PENDING
  FAILED
  REFUNDED
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum DealStage {
  PROSPECT
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
}

enum ProjectStage {
  ONBOARDING
  DESIGN
  DEVELOPMENT
  REVIEW
  LAUNCHED
}

enum BillingType {
  ONE_TIME
  MONTHLY
}

enum PlanRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PlanRequestSource {
  QUOTE
  CHECKOUT
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
}

enum HermesEventStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum BookingStatus {
  CONFIRMED
  PENDING
  CANCELED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum DeliveryTaskKind {
  ONE_TIME
  RECURRING
}

enum DeliveryRecurrence {
  NONE
  MONTHLY
}
