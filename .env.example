# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Initial Admin Bootstrap (optional for seed) ─────────────────────────
# Seed will only create/update an admin user when both are set.
ADMIN_EMAIL="owner@yourcompany.com"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_NAME="Site Admin"

# ── Resend (email) ────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_api_key_here"
# Email address that receives new lead notifications
LEAD_NOTIFICATION_EMAIL="you@example.com"
# Resend-hosted template ID used for the welcome email sent on signup.
# Created in the Resend dashboard as "welcome-email". Override here to
# point staging at a different template without code changes.
RESEND_WELCOME_TEMPLATE_ID="6d9e480c-9f79-415f-bc13-a3715e03c4d2"

# ── SEO Audit pipeline ────────────────────────────────────────────────────
# Required to run audits from /admin/audits.

# Google PageSpeed Insights — Technical SEO scores + Core Web Vitals.
# Free. Get from Google Cloud Console → APIs & Services → Credentials.
GOOGLE_PAGESPEED_API_KEY=""

# Google Places API — Google Business Profile data for the Local SEO module.
# Free up to ~$200/mo of usage. Same Cloud project as PageSpeed is fine,
# just enable the Places API.
GOOGLE_PLACES_API_KEY=""

# DataForSEO — backlink profile data. Pay-per-use (~$0.01 / audit).
# Get credentials at dataforseo.com.
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# Public app URL (used by the PDF generator to render the report route via
# Puppeteer). Defaults to http://localhost:3000 in development.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Vercel AI Gateway (for AI Content Plan generation) ───────────────────
# When deploying to Vercel, the gateway picks this up automatically. For
# local dev / non-Vercel hosting, set it explicitly. Get from
# https://vercel.com/dashboard → AI Gateway → Keys.
AI_GATEWAY_API_KEY=""

# ── PDF report contact info ───────────────────────────────────────────────
# Surfaced in the closing CTA section of the client-facing PDF audit report.
# All three are optional — leave any blank to omit it from the report.
MACROLIGHT_CONTACT_URL=""    # e.g. https://macrolightbuilders.com/book
MACROLIGHT_CONTACT_EMAIL=""  # e.g. hello@macrolightbuilders.com
MACROLIGHT_CONTACT_PHONE=""  # e.g. +1-555-555-5555

# ── Vercel Blob (file/media storage) ─────────────────────────────────────
# Get from Vercel dashboard → Storage → Blob → your store → .env.local.
# Required for client portal media uploads and serving private files.
BLOB_READ_WRITE_TOKEN=""

# ── Stripe ────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Get from https://dashboard.stripe.com/webhooks after creating an endpoint
STRIPE_WEBHOOK_SECRET=""

# ── Microsoft Clarity (session recordings + heatmaps) ────────────────────
# Free, unlimited sessions. Sign up at https://clarity.microsoft.com,
# create a project, and paste its Project ID (short alphanumeric token —
# NOT the whole install snippet). Leave blank to disable the tracker.
NEXT_PUBLIC_CLARITY_PROJECT_ID=""

# ── Cal.com booking embed ────────────────────────────────────────────────
# Used by both the public /book page and /portal/book-a-call. Set up an
# event type at cal.com, then paste your username and the event URL slug
# below. Booking URL becomes https://cal.com/{username}/{slug}.
# See CAL_SETUP.md for full setup (including the webhook + DB sync).
NEXT_PUBLIC_CAL_USERNAME=""
NEXT_PUBLIC_CAL_EVENT_SLUG=""

# ── Google Ads Conversion API ─────────────────────────────────────────────
# Used for server-side conversion tracking on audit/signup form submissions.
# Required only when running Google Ads campaigns.
#
# Developer token: Google Ads UI → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=""
# 10-digit customer ID (no dashes)
GOOGLE_ADS_CUSTOMER_ID=""
# Numeric conversion action ID (from the conversion action URL in Google Ads)
GOOGLE_ADS_CONVERSION_ACTION_ID=""
# OAuth2 credentials — create at Google Cloud Console → APIs & Services → Credentials
GOOGLE_ADS_OAUTH_CLIENT_ID=""
GOOGLE_ADS_OAUTH_CLIENT_SECRET=""
# Long-lived refresh token — obtain via the OAuth 2.0 Playground or a one-time local script
GOOGLE_ADS_OAUTH_REFRESH_TOKEN=""
# Manager (MCC) account ID — only required if your account is under a manager account
GOOGLE_ADS_MANAGER_CUSTOMER_ID=""
