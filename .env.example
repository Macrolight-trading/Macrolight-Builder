# ── Database (Neon Postgres) ──────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Initial Admin Bootstrap (optional for seed) ─────────────────────────
# Seed will only create/update an admin user when both are set.
ADMIN_EMAIL="owner@yourcompany.com"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_NAME="Site Admin"

# ── Resend (email) ────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_api_key_here"
# Email address that receives new lead notifications
LEAD_NOTIFICATION_EMAIL="you@example.com"
